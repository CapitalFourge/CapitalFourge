# ============================================================
# Capital Fourge - Environment Configuration Template
# ============================================================
# Copy this file to .env and fill in your own values.
# DO NOT commit .env to version control.
# ============================================================

# --- Application Environment ---
APP_ENV=development

# --- PostgreSQL ---
DB_POSTGRES_USER=
DB_POSTGRES_PASSWORD=
DB_POSTGRES_NAME=capital_fourge_db
DB_POSTGRES_PORT=5432

# --- MongoDB ---
DB_MONGO_ROOT_USER=
DB_MONGO_ROOT_PASSWORD=
DB_MONGO_PORT=27017

# --- Redis ---
DB_REDIS_PASSWORD=
DB_REDIS_PORT=6379
DB_REDIS_HOST=redis

# --- EIA API Key (U.S. Energy Information Administration) ---
# Get yours at: https://www.eia.gov/opendata/
EIA_API_KEY=

# --- gRPC Data Collector ---
GRPC_DATA_COLLECTOR_HOST=data-collector
GRPC_DATA_COLLECTOR_PORT=50051

# --- FastAPI / Data Collector ---
DATA_COLLECTOR_PORT=8000
DATA_COLLECTOR_RELOAD=true
DATA_COLLECTOR_API_KEY=internal-service-key

# --- Portfolio Manager (Java) ---
PORTFOLIO_MANAGER_PORT=8080

# --- CORS Settings ---
# Comma-separated list of allowed origins
CORS_ORIGINS=*

# --- Application Secrets (REQUIRED for production) ---
# Generate with: openssl rand -hex 32
JWT_SECRET=
SESSION_SECRET=
