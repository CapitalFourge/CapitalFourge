# ============================================================
# Capital Fourge - Production Environment Template
# ============================================================
# Use this as a reference for deploying to production.
# Each value MUST be overridden with secure, production-grade secrets.
# ============================================================

# --- Application Environment ---
APP_ENV=production

# --- PostgreSQL (managed database required) ---
DB_POSTGRES_USER=capital_admin
DB_POSTGRES_PASSWORD=<GENERATE_STRONG_PASSWORD_32CHARS>
DB_POSTGRES_NAME=capital_fourge_db
DB_POSTGRES_PORT=5432

# --- MongoDB (managed database recommended) ---
DB_MONGO_ROOT_USER=mongo_admin
DB_MONGO_ROOT_PASSWORD=<GENERATE_STRONG_PASSWORD_32CHARS>
DB_MONGO_PORT=27017

# --- Redis (managed Redis or dedicated server) ---
DB_REDIS_PASSWORD=<GENERATE_STRONG_PASSWORD_32CHARS>
DB_REDIS_PORT=6379
DB_REDIS_HOST=redis

# --- EIA API Key ---
# Use a dedicated key for production
EIA_API_KEY=

# --- gRPC Data Collector ---
GRPC_DATA_COLLECTOR_HOST=data-collector
GRPC_DATA_COLLECTOR_PORT=50051

# --- FastAPI / Data Collector ---
DATA_COLLECTOR_PORT=8000
DATA_COLLECTOR_RELOAD=false
DATA_COLLECTOR_API_KEY=<GENERATE_STRONG_RANDOM_KEY>

# --- Portfolio Manager (Java) ---
PORTFOLIO_MANAGER_PORT=8080

# --- CORS Settings (RESTRICT IN PRODUCTION) ---
# Replace with your actual domain(s)
CORS_ORIGINS=https://tu-dominio.com,https://www.tu-dominio.com

# --- Application Secrets (MANDATORY) ---
# Generate with: openssl rand -hex 32
JWT_SECRET=<openssl_rand_hex_32>
SESSION_SECRET=<openssl_rand_hex_32>
